{
    "manifest_version" : 3,
    "name" : "Linkedin SN Fixer",
    "description" : "Browser add-on to fix various stupidities and annoyances in Linkedin Sales Navigator.",
    "version" : "2.1.0",
    "action" : {
        "default_title" : "LNSNFixer",
        "default_popup" : "popup.html"
    },
    "content_scripts" : [
        {
            "matches" : ["https://www.linkedin.com/sales/*", "https://www.linkedin.com/in/*"],
            "css" : ["mystyles_A.css"],
            "js" : ["snf-globals.js", "snf-utils.js", "snf-database.js", "snf-counter.js", "snf-lead-page.js", "snf-search-page.js"]
        }
    ],
"permissions" : [
        "scripting",
        "tabs",
        "chrome://*/*",
        "https://*/*"
    ],
    "host_permissions": [
        "https://www.linkedin.com/"
    ],
    "web_accessible_resources": [
    {
        "resources": ["database_urls.json"],
        "matches": ["<all_urls>"]
    }
    ],
    "optional_host_permissions": [
        "*://*/*"
    ]
}